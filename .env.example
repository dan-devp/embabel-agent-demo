# OpenAI API Key (required)
OPENAI_API_KEY=sk-proj-...

# Host-Port des Backends (intern läuft Spring immer auf 8088)
SERVER_PORT=8088

# Embabel Model Config
#EMBABEL_MODELS_DEFAULT_LLM=gpt-4.1-mini
#EMBABEL_MODELS_REVIEWER_LLM=gpt-4.1-mini

# Embabel Logging
#EMBABEL_AGENT_LOGGING_PERSONALITY=severance

# Observability / Tracing
#MANAGEMENT_TRACING_ENABLED=true
#MANAGEMENT_TRACING_SAMPLING_PROBABILITY=1.0
